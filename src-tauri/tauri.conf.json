{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/config.json",
  "productName": "TTPlayer-Next",
  "version": "0.1.0",
  "identifier": "com.ttplayer-next.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TTPlayer-Next",
        "width": 820,
        "height": 620,
        "resizable": true,
        "decorations": false,
        "center": true,
        "minWidth": 520,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; font-src 'self' data:; connect-src 'self' https: ipc: http://localhost:*; frame-src 'none'; object-src 'none'; base-uri 'none'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
